# ============================================================
# apps/api/.env.example
# Copie para .env e preencha os valores
# NUNCA commite o arquivo .env no Git
# ============================================================

# ── Servidor ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001

# ── Banco de Dados ────────────────────────────────────────────
DATABASE_URL="postgresql://hidrobr:hidrobr_dev_2025@localhost:5432/hidrobr_gistm"

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ───────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=TROQUE_POR_UM_SECRET_SEGURO_DE_64_CHARS
JWT_REFRESH_SECRET=TROQUE_POR_OUTRO_SECRET_SEGURO_DIFERENTE
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Frontend (CORS) ───────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── MinIO / S3 ────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=hidrobr_minio
S3_SECRET_KEY=hidrobr_minio_2025
S3_REGION=us-east-1
S3_BUCKET_EVIDENCES=hidrobr-evidences
S3_BUCKET_ACADEMY=hidrobr-academy
S3_BUCKET_REPORTS=hidrobr-reports
S3_BUCKET_AVATARS=hidrobr-avatars

# ── Email (dev: usa Ethereal — não envia e-mail real) ─────────
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="HIDROBR GISTM <noreply@hidrobr.com.br>"

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
