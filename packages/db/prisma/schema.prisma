// ============================================================
// packages/db/prisma/schema.prisma
// HIDROBR GISTM Manager — Schema completo do banco de dados
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────

enum UserRole {
  hidrobr_admin
  hidrobr_consultant
  client_admin
  client_user
  readonly
}

enum RequirementStatus {
  not_started
  in_progress
  submitted
  under_review
  approved
  needs_revision
}

enum AssessmentScore {
  non_conforming
  partially_conforming
  conforming
  fully_conforming
  not_applicable
}

enum EvidenceType {
  document
  image
  spreadsheet
  report
  video
  link
  other
}

enum NotificationType {
  assessment_requested
  assessment_completed
  evidence_uploaded
  revision_requested
  deadline_reminder
  academy_content
  system_alert
}

enum ContentType {
  video
  article
  webinar
  document
  quiz
  infographic
}

enum TrailStatus {
  draft
  published
  archived
}

enum CycleStatus {
  active
  completed
  archived
  suspended
}

enum ActionPriority {
  critical
  high
  medium
  low
}

enum ActionStatus {
  open
  in_progress
  completed
  cancelled
  overdue
}

// ─── G1: IDENTIDADE & ACESSO ─────────────────────────────────

model Organization {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name          String    @db.VarChar(255)
  cnpj          String?   @unique @db.VarChar(18)
  segment       String?   @db.VarChar(100)
  logoUrl       String?   @map("logo_url")
  address       Json      @default("{}") @db.JsonB
  contacts      Json      @default("{}") @db.JsonB
  contractStart DateTime? @map("contract_start") @db.Date
  contractEnd   DateTime? @map("contract_end") @db.Date
  isActive      Boolean   @default(true) @map("is_active")
  settings      Json      @default("{}") @db.JsonB
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  users        User[]
  facilities   TailingsFacility[]
  cycles       AssessmentCycle[]
  actionItems  ActionItem[]
  trailAssigns LearningTrail[]    @relation("TrailTargetOrg")
  notifications Notification[]

  @@map("organizations")
}

model User {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  email          String    @unique @db.VarChar(255)
  passwordHash   String    @map("password_hash")
  role           UserRole
  fullName       String    @map("full_name") @db.VarChar(255)
  avatarUrl      String?   @map("avatar_url")
  jobTitle       String?   @map("job_title") @db.VarChar(150)
  phone          String?   @db.VarChar(30)
  isActive       Boolean   @default(true) @map("is_active")
  lastLogin      DateTime? @map("last_login")
  mfaSecret      String?   @map("mfa_secret")
  preferences    Json      @default("{}") @db.JsonB
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization         Organization?        @relation(fields: [organizationId], references: [id])
  sessions             UserSession[]
  assignedCycles       AssessmentCycle[]    @relation("CycleConsultant")
  responseHistories    ResponseHistory[]
  assessments          HidroBrAssessment[]
  uploadedEvidences    Evidence[]
  validatedEvidences   Evidence[]           @relation("EvidenceValidator")
  comments             Comment[]
  notifications        Notification[]
  trailsCreated        LearningTrail[]
  contentsCreated      AcademyContent[]
  progress             UserProgress[]
  certificates         Certificate[]
  actionItemsOwned     ActionItem[]         @relation("ActionOwner")
  actionItemsCreated   ActionItem[]         @relation("ActionCreator")
  actionComments       ActionComment[]
  auditLogs            AuditLog[]

  @@index([organizationId])
  @@index([role])
  @@index([email])
  @@map("users")
}

model UserSession {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @map("token_hash")
  family     String   @db.VarChar(64)
  expiresAt  DateTime @map("expires_at")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([family])
  @@map("user_sessions")
}

// ─── G2: ESTRUTURA GISTM (seed estático) ─────────────────────

model GistmTopic {
  id           Int      @id @default(autoincrement())
  code         String   @unique @db.VarChar(10)
  title        String   @db.VarChar(255)
  description  String?
  displayOrder Int      @map("display_order") @db.SmallInt
  colorHex     String?  @map("color_hex") @db.VarChar(7)
  icon         String?  @db.VarChar(50)

  requirements GistmRequirement[]

  @@map("gistm_topics")
}

model GistmRequirement {
  id              Int     @id @default(autoincrement())
  topicId         Int     @map("topic_id")
  code            String  @unique @db.VarChar(10)
  title           String  @db.VarChar(500)
  description     String
  guidance        String?
  referenceDocs   Json    @default("[]") @map("reference_docs") @db.JsonB
  displayOrder    Int     @map("display_order") @db.SmallInt
  weight          Decimal @default(1.0) @db.Decimal(5, 2)
  subRequirements Json    @default("[]") @map("sub_requirements") @db.JsonB

  topic             GistmTopic              @relation(fields: [topicId], references: [id])
  responses         RequirementResponse[]
  linkedContents    AcademyContent[]

  @@index([topicId])
  @@map("gistm_requirements")
}

// ─── G3: ATIVOS DO CLIENTE ───────────────────────────────────

model TailingsFacility {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId      String    @map("organization_id") @db.Uuid
  name                String    @db.VarChar(255)
  damCode             String?   @map("dam_code") @db.VarChar(50)
  location            Json      @default("{}") @db.JsonB
  damType             String?   @map("dam_type") @db.VarChar(100)
  consequenceClass    String?   @map("consequence_class") @db.VarChar(20)
  currentVolume       Decimal?  @map("current_volume") @db.Decimal(15, 2)
  totalCapacity       Decimal?  @map("total_capacity") @db.Decimal(15, 2)
  heightMeters        Decimal?  @map("height_meters") @db.Decimal(8, 2)
  constructionYear    Int?      @map("construction_year") @db.SmallInt
  operationalStatus   String?   @map("operational_status") @db.VarChar(50)
  assignedEngineer    String?   @map("assigned_engineer") @db.VarChar(255)
  metadata            Json      @default("{}") @db.JsonB
  isActive            Boolean   @default(true) @map("is_active")
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id])
  cycles       AssessmentCycle[]

  @@index([organizationId])
  @@map("tailings_facilities")
}

// ─── G4: CICLOS & RESPOSTAS ───────────────────────────────────

model AssessmentCycle {
  id                  String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId      String      @map("organization_id") @db.Uuid
  facilityId          String      @map("facility_id") @db.Uuid
  name                String      @db.VarChar(255)
  referenceYear       Int         @map("reference_year") @db.SmallInt
  startDate           DateTime    @map("start_date") @db.Date
  targetDate          DateTime?   @map("target_date") @db.Date
  completedDate       DateTime?   @map("completed_date") @db.Date
  status              CycleStatus @default(active)
  assignedConsultant  String?     @map("assigned_consultant") @db.Uuid
  overallScore        Decimal?    @map("overall_score") @db.Decimal(5, 2)
  metadata            Json        @default("{}") @db.JsonB
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  organization Organization        @relation(fields: [organizationId], references: [id])
  facility     TailingsFacility    @relation(fields: [facilityId], references: [id])
  consultant   User?               @relation("CycleConsultant", fields: [assignedConsultant], references: [id])
  responses    RequirementResponse[]

  @@index([organizationId])
  @@index([facilityId])
  @@map("assessment_cycles")
}

model RequirementResponse {
  id                  String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  cycleId             String            @map("cycle_id") @db.Uuid
  requirementId       Int               @map("requirement_id")
  status              RequirementStatus @default(not_started)
  implementationText  String?           @map("implementation_text")
  implementationDate  DateTime?         @map("implementation_date") @db.Date
  responsiblePerson   String?           @map("responsible_person") @db.VarChar(255)
  notes               String?
  subReqResponses     Json              @default("{}") @map("sub_req_responses") @db.JsonB
  submittedAt         DateTime?         @map("submitted_at")
  revisionCount       Int               @default(0) @map("revision_count") @db.SmallInt
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  cycle       AssessmentCycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  requirement GistmRequirement   @relation(fields: [requirementId], references: [id])
  assessment  HidroBrAssessment?
  evidences   Evidence[]
  history     ResponseHistory[]
  comments    Comment[]

  @@unique([cycleId, requirementId])
  @@index([cycleId])
  @@index([cycleId, status])
  @@map("requirement_responses")
}

model ResponseHistory {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  responseId     String   @map("response_id") @db.Uuid
  changedBy      String   @map("changed_by") @db.Uuid
  changeType     String   @map("change_type") @db.VarChar(30)
  snapshotBefore Json     @map("snapshot_before") @db.JsonB
  snapshotAfter  Json     @map("snapshot_after") @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at")

  response RequirementResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  user     User                @relation(fields: [changedBy], references: [id])

  @@index([responseId])
  @@map("response_history")
}

// ─── G5: AVALIAÇÕES HIDROBR ───────────────────────────────────

model HidroBrAssessment {
  id              String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  responseId      String          @unique @map("response_id") @db.Uuid
  assessedBy      String          @map("assessed_by") @db.Uuid
  score           AssessmentScore
  scoreValue      Int             @map("score_value") @db.SmallInt
  assessmentText  String          @map("assessment_text")
  recommendations String?
  internalNotes   String?         @map("internal_notes")
  attachments     Json            @default("[]") @db.JsonB
  publishedAt     DateTime        @map("published_at")
  revisedAt       DateTime?       @map("revised_at")
  revisedBy       String?         @map("revised_by") @db.Uuid

  response  RequirementResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  assessor  User                @relation(fields: [assessedBy], references: [id])

  @@index([responseId])
  @@map("hidrobr_assessments")
}

// ─── G6: EVIDÊNCIAS ───────────────────────────────────────────

model Evidence {
  id          String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  responseId  String       @map("response_id") @db.Uuid
  uploadedBy  String       @map("uploaded_by") @db.Uuid
  fileName    String       @map("file_name") @db.VarChar(500)
  s3Key       String       @unique @map("s3_key")
  fileSize    BigInt?      @map("file_size")
  fileType    EvidenceType @default(document) @map("file_type")
  mimeType    String?      @map("mime_type") @db.VarChar(100)
  description String?
  tags        String[]     @default([])
  isValid     Boolean      @default(true) @map("is_valid")
  validatedBy String?      @map("validated_by") @db.Uuid
  validatedAt DateTime?    @map("validated_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  response  RequirementResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  uploader  User                @relation(fields: [uploadedBy], references: [id])
  validator User?               @relation("EvidenceValidator", fields: [validatedBy], references: [id])

  @@index([responseId])
  @@map("evidences")
}

// ─── G7: PLANO DE AÇÃO ───────────────────────────────────────

model ActionItem {
  id             String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  requirementCode String?       @map("requirement_code") @db.VarChar(10)
  title          String         @db.VarChar(500)
  description    String?
  priority       ActionPriority @default(medium)
  status         ActionStatus   @default(open)
  dueDate        DateTime?      @map("due_date") @db.Date
  completedAt    DateTime?      @map("completed_at")
  ownerId        String?        @map("owner_id") @db.Uuid
  createdBy      String         @map("created_by") @db.Uuid
  metadata       Json           @default("{}") @db.JsonB
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  organization Organization   @relation(fields: [organizationId], references: [id])
  owner        User?          @relation("ActionOwner", fields: [ownerId], references: [id])
  creator      User           @relation("ActionCreator", fields: [createdBy], references: [id])
  comments     ActionComment[]

  @@index([organizationId])
  @@index([status])
  @@index([dueDate])
  @@map("action_items")
}

model ActionComment {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  actionItemId String   @map("action_item_id") @db.Uuid
  authorId     String   @map("author_id") @db.Uuid
  body         String
  createdAt    DateTime @default(now()) @map("created_at")

  actionItem ActionItem @relation(fields: [actionItemId], references: [id], onDelete: Cascade)
  author     User       @relation(fields: [authorId], references: [id])

  @@map("action_comments")
}

// ─── G8: ACADEMY ─────────────────────────────────────────────

model AcademyCategory {
  id           Int     @id @default(autoincrement())
  name         String  @db.VarChar(150)
  slug         String  @unique @db.VarChar(150)
  description  String?
  icon         String? @db.VarChar(50)
  displayOrder Int     @default(0) @map("display_order") @db.SmallInt
  isActive     Boolean @default(true) @map("is_active")

  contents AcademyContent[]

  @@map("academy_categories")
}

model AcademyContent {
  id              String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  categoryId      Int?        @map("category_id")
  requirementId   Int?        @map("requirement_id")
  title           String      @db.VarChar(500)
  slug            String      @unique @db.VarChar(500)
  summary         String?
  body            String?
  contentType     ContentType @map("content_type")
  mediaUrl        String?     @map("media_url")
  thumbnailUrl    String?     @map("thumbnail_url")
  durationMinutes Int?        @map("duration_minutes") @db.SmallInt
  difficultyLevel String?     @map("difficulty_level") @db.VarChar(20)
  language        String      @default("pt-BR") @db.VarChar(10)
  tags            String[]    @default([])
  isPublished     Boolean     @default(false) @map("is_published")
  publishedAt     DateTime?   @map("published_at")
  createdBy       String?     @map("created_by") @db.Uuid
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  category    AcademyCategory?  @relation(fields: [categoryId], references: [id])
  requirement GistmRequirement? @relation(fields: [requirementId], references: [id])
  creator     User?             @relation(fields: [createdBy], references: [id])
  trailItems  TrailContent[]
  progress    UserProgress[]

  @@index([isPublished])
  @@index([categoryId])
  @@map("academy_contents")
}

model LearningTrail {
  id             String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  createdBy      String      @map("created_by") @db.Uuid
  title          String      @db.VarChar(300)
  description    String?
  thumbnailUrl   String?     @map("thumbnail_url")
  targetRole     UserRole?   @map("target_role")
  targetOrgId    String?     @map("target_org_id") @db.Uuid
  status         TrailStatus @default(draft)
  estimatedHours Decimal?    @map("estimated_hours") @db.Decimal(5, 1)
  metadata       Json        @default("{}") @db.JsonB
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  creator      User           @relation(fields: [createdBy], references: [id])
  targetOrg    Organization?  @relation("TrailTargetOrg", fields: [targetOrgId], references: [id])
  contents     TrailContent[]
  progress     UserProgress[]
  certificates Certificate[]

  @@index([status])
  @@index([targetOrgId])
  @@map("learning_trails")
}

model TrailContent {
  id           String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  trailId      String  @map("trail_id") @db.Uuid
  contentId    String  @map("content_id") @db.Uuid
  displayOrder Int     @map("display_order") @db.SmallInt
  isRequired   Boolean @default(true) @map("is_required")

  trail   LearningTrail  @relation(fields: [trailId], references: [id], onDelete: Cascade)
  content AcademyContent @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([trailId, contentId])
  @@map("trail_contents")
}

model UserProgress {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  contentId     String    @map("content_id") @db.Uuid
  trailId       String?   @map("trail_id") @db.Uuid
  completed     Boolean   @default(false)
  progressPct   Int       @default(0) @map("progress_pct") @db.SmallInt
  timeSpentSec  Int       @default(0) @map("time_spent_sec")
  quizScore     Decimal?  @map("quiz_score") @db.Decimal(5, 2)
  lastAccessed  DateTime? @map("last_accessed")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  content AcademyContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  trail   LearningTrail? @relation(fields: [trailId], references: [id])

  @@unique([userId, contentId, trailId])
  @@index([userId])
  @@map("user_progress")
}

model Certificate {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  trailId        String   @map("trail_id") @db.Uuid
  certificateUrl String?  @map("certificate_url")
  issuedAt       DateTime @default(now()) @map("issued_at")

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  trail LearningTrail @relation(fields: [trailId], references: [id])

  @@unique([userId, trailId])
  @@map("certificates")
}

// ─── G9: COMUNICAÇÃO ─────────────────────────────────────────

model Comment {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  responseId String   @map("response_id") @db.Uuid
  authorId   String   @map("author_id") @db.Uuid
  body       String
  isInternal Boolean  @default(false) @map("is_internal")
  parentId   String?  @map("parent_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  response RequirementResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  author   User                @relation(fields: [authorId], references: [id])
  parent   Comment?            @relation("CommentThread", fields: [parentId], references: [id])
  replies  Comment[]           @relation("CommentThread")

  @@index([responseId])
  @@map("comments")
}

model Notification {
  id             String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  organizationId String?          @map("organization_id") @db.Uuid
  type           NotificationType
  title          String           @db.VarChar(255)
  body           String?
  link           String?
  isRead         Boolean          @default(false) @map("is_read")
  metadata       Json             @default("{}") @db.JsonB
  createdAt      DateTime         @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ─── G10: AUDITORIA ──────────────────────────────────────────

model AuditLog {
  id             BigInt   @id @default(autoincrement())
  userId         String?  @map("user_id") @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  action         String   @db.VarChar(100)
  resourceType   String?  @map("resource_type") @db.VarChar(50)
  resourceId     String?  @map("resource_id")
  details        Json?    @db.JsonB
  ipAddress      String?  @map("ip_address") @db.VarChar(45)
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([action])
  @@map("audit_log")
}
